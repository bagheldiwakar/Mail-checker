# Email (IMAP) — works with Gmail, Outlook, Yahoo, etc.
EMAIL_ADDRESS=your.email@gmail.com
EMAIL_PASSWORD=your-app-password
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# SMTP — used to send alert emails (Render / cloud mode)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
ALERT_EMAIL=

# Groq — free tier AI classification
GROQ_API_KEY=gsk-your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# How often to check for new mail when running locally (seconds)
POLL_INTERVAL=120

# Keep each Render request short and avoid Groq rate limits
MAX_EMAILS_PER_CHECK=5
GROQ_REQUEST_DELAY_SECONDS=2

# Optional: your name so the AI can spot profile-specific outreach
YOUR_NAME=Your Name

# auto | desktop | email | ntfy
NOTIFIER_MODE=auto

# Optional phone push notifications with the ntfy app
NTFY_TOPIC=mail-checker-your-private-random-topic
NTFY_SERVER=https://ntfy.sh
